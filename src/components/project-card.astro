---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
const { project, allImages } = Astro.props;

const optimizedImages = await Promise.all(
  project.images.map(async (imgName: string) => {
    const path = `/src/assets/${imgName}`;
    if (allImages[path]) {
      const mod = await allImages[path]();
      return mod.default;
    }
    return null; // Fallback for '#' or missing files
  }),
);

const isSlider = optimizedImages.filter(Boolean).length > 1;
---

<div
  class="project-card group relative bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-500"
>
  <div class="aspect-3/2 overflow-hidden relative bg-background/50">
    <div class="absolute inset-0 transition-colors z-10 pointer-events-none"></div>

    <div class={`w-full h-full relative ${isSlider ? "image-slider" : ""}`}>
      {
        optimizedImages.map((imgMetadata, index) => {
          if (!imgMetadata) {
            // Fallback for the "#" or missing images in JSON
            return (
              <div class="absolute inset-0 bg-gray-800 flex items-center justify-center">
                No Image
              </div>
            );
          }

          return (
            <Image
              src={imgMetadata}
              alt={`${project.title} screenshot ${index + 1}`}
              width={1200}
              height={800}
              class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 ${index === 0 ? "opacity-100 z-0" : "opacity-0 z-[-1]"}`}
            />
          );
        })
      }
    </div>
  </div>

  <div class="p-6 space-y-4">
    <div class="flex justify-between items-start">
      <div>
        <span class="text-accent text-[10px] uppercase tracking-widest font-bold"
          >{project.category}</span
        >
        <h3 class="text-xl font-heading font-bold text-maintext mt-1">{project.title}</h3>
      </div>
      <a
        href={project.link}
        target="_blank"
        class="text-accent/75 hover:text-accent transition-colors"
      >
        <Icon name="mdi:open-in-new" class="w-6 h-6" />
      </a>
    </div>

    <p class="text-subtext text-sm font-body line-clamp-3">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-2 pt-2">
      {
        project.tech.map((t: string) => (
          <span class="rounded-md text-[10px] px-2 md:px-4 py-1 bg-accent/5 border border-accent/10 text-accent/80  group-hover:border-accent/40 group-hover:text-accent">
            {t}
          </span>
        ))
      }
    </div>
  </div>
</div>

<script>
  function initSliders() {
    const sliders = document.querySelectorAll(".image-slider");

    sliders.forEach((slider) => {
      const images = slider.querySelectorAll("img");
      if (images.length <= 1) return;

      let currentIndex = 0;
      setInterval(() => {
        // Hide current
        images[currentIndex].classList.remove("opacity-100", "z-0");
        images[currentIndex].classList.add("opacity-0", "z-[-1]");

        // Move to next
        currentIndex = (currentIndex + 1) % images.length;

        // Show next
        images[currentIndex].classList.remove("opacity-0", "z-[-1]");
        images[currentIndex].classList.add("opacity-100", "z-0");
      }, 3500);
    });
  }

  initSliders();
  document.addEventListener("astro:after-swap", initSliders);
</script>

<style is:global>
  .project-card {
    opacity: 0;
    visibility: hidden;
    transform: translateY(40px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.8s;
    will-change: transform, opacity;
  }

  .project-card.reveal {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>
